# Copy this file to .env and fill in real values.
# cp .env.example .env

# Postgres connection string (Neon, Supabase, local Postgres, etc.)
DATABASE_URL=

# Clerk (https://dashboard.clerk.com) — Configure > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Google Generative AI (https://aistudio.google.com/apikey) — used for chat completions
GOOGLE_GENERATIVE_AI_API_KEY=

# Tavily (https://app.tavily.com) — used by the webSearch tool
TAVILY_API_KEY=
